{
  "enabledPlugins": {
    "expo@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(npm run icon *)",
      "WebFetch(domain:docs.expo.dev)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // \"\"'); case \"$f\" in *.ts|*.tsx) npx tsc --noEmit 1>&2 || exit 2 ;; esac",
            "timeout": 60,
            "statusMessage": "型検証中 (npx tsc --noEmit)"
          }
        ]
      }
    ]
  }
}
